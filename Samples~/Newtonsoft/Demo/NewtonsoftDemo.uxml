<engine:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:engine="UnityEngine.UIElements" xmlns:editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <engine:VisualElement class="size-full bg-coral-900" style="align-items: center; justify-content: space-evenly;">
        <engine:VisualElement>
            <engine:Label text="Guide" style="font-size: 48px;" />
            <engine:Label text="This implementation demonstrates the use of Newtonsoft JSON.&#10;&#10;To integrate it with UIs in Luna, such as MainMenu and GameSaveView, simply change the SaveManager reference. &#10;The UI remains unaffected by the implementation details.&#10;&#10;Refer to the Game Sample to see how UIs are structured." style="white-space: normal;" />
        </engine:VisualElement>
        <engine:VisualElement>
            <engine:Label text="Demo" style="font-size: 48px;" />
            <engine:Label text="Click on `Tools &gt; CupkekGames &gt; Open Persistant Data Path` to open the persistant data path in the file explorer." style="white-space: normal;" />
            <engine:Label text="You can edit the json files and load them back." style="white-space: normal;" />
        </engine:VisualElement>
        <engine:VisualElement class="w-full" style="flex-direction: row; align-items: center; justify-content: space-evenly;">
            <engine:Label text="Label" name="Current" />
            <engine:Label text="Label" name="Saved" />
        </engine:VisualElement>
        <engine:VisualElement class="w-full" style="flex-direction: row; justify-content: space-evenly;">
            <engine:VisualElement>
                <engine:VisualElement style="flex-grow: 1; flex-direction: row;">
                    <engine:Button text="AddGold" name="AddGold" class="btn" />
                    <engine:Button text="RemoveGold" name="RemoveGold" class="btn" />
                </engine:VisualElement>
                <engine:VisualElement style="flex-grow: 1; flex-direction: row;">
                    <engine:Button text="AddRandomItem" name="AddRandomItem" class="btn" />
                    <engine:Button text="RemoveRandomItem" name="RemoveRandomItem" class="btn" />
                </engine:VisualElement>
                <engine:Button text="Save" name="Save" class="btn" />
            </engine:VisualElement>
            <engine:Button text="Load" name="Load" class="btn" />
        </engine:VisualElement>
    </engine:VisualElement>
</engine:UXML>
